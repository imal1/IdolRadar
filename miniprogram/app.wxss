page {
  min-height: 100%;
  background: linear-gradient(180deg, #fdf3f0 0%, #faf6f3 30%, #f7f3f1 100%);
  color: #3d2f33;
  font-family: -apple-system, "PingFang SC", "Helvetica Neue", "Microsoft YaHei", sans-serif;
  font-size: 27rpx;
}

view,
text,
image,
button,
input {
  box-sizing: border-box;
}

button {
  margin: 0;
  padding: 0;
  border-radius: 0;
  line-height: normal;
  width: auto;
  min-width: 0;
  font-size: inherit;
  color: inherit;
  background: transparent;
  text-align: inherit;
}

button::after {
  border: 0;
}

.page-shell {
  min-height: 100vh;
  padding: 19rpx 31rpx calc(138rpx + env(safe-area-inset-bottom));
  padding-top: calc(env(safe-area-inset-top, 0rpx) + 96rpx);
}

.page-title {
  padding: 12rpx 0 4rpx;
  color: #3d2f33;
  font-size: 31rpx;
  font-weight: 600;
  text-align: center;
}

.state-card {
  padding: 69rpx 35rpx;
  border-radius: 38rpx;
  background: #ffffff;
  box-shadow: 0 8rpx 31rpx rgba(61, 46, 51, 0.05);
  text-align: center;
}

.state-title {
  display: block;
  color: #3d2f33;
  font-size: 29rpx;
  font-weight: 600;
}

.state-copy {
  display: block;
  margin-top: 12rpx;
  color: #a58a94;
  font-size: 23rpx;
  line-height: 1.6;
}

.primary-button {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 13rpx 25rpx;
  border-radius: 25rpx;
  background: linear-gradient(135deg, #e78aa4, #c4526e);
  color: #ffffff;
  font-size: 23rpx;
  font-weight: 600;
}

.secondary-button {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 13rpx 25rpx;
  border-radius: 25rpx;
  background: #fdf0f3;
  color: #c4526e;
  font-size: 23rpx;
  font-weight: 600;
}

.state-action {
  margin-top: 27rpx;
}
