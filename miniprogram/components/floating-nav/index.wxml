<view class="nav-backdrop" wx:if="{{open}}" catchtap="close"></view>
<view class="floating-nav {{snapping ? 'snapping' : ''}}" style="transform:translate({{dragX}}px,{{dragY}}px)">
  <view class="nav-menu" wx:if="{{open}}">
    <view
      wx:for="{{items}}"
      wx:key="key"
      class="nav-item nav-item-{{index}} {{current === item.key ? 'nav-item-current' : ''}}"
      data-key="{{item.key}}"
      data-path="{{item.path}}"
      catchtap="navigate"
      aria-role="button"
      aria-label="前往{{item.label}}页"
    >{{item.label}}</view>
  </view>
  <view
    class="nav-trigger"
    catchtouchstart="dragStart"
    catchtouchmove="dragMove"
    catchtouchend="dragEnd"
    aria-role="button"
    aria-label="{{open ? '收起页面导航' : '展开页面导航'}}"
  >{{open ? '×' : '❀'}}</view>
</view>
