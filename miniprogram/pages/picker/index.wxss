.picker-page {
  display: flex;
  flex-direction: column;
  gap: 27rpx;
}

.picker-intro {
  padding: 12rpx 8rpx 0;
}

.picker-title,
.picker-subtitle {
  display: block;
}

.picker-title {
  color: #3d2f33;
  font-size: 42rpx;
  font-weight: 700;
}

.picker-subtitle {
  margin-top: 19rpx;
  color: #a58a94;
  font-size: 24rpx;
}

.search-box {
  display: flex;
  align-items: center;
  gap: 15rpx;
  min-height: 73rpx;
  padding: 0 27rpx;
  border-radius: 31rpx;
  background: #ffffff;
  box-shadow: 0 6rpx 19rpx rgba(61, 46, 51, 0.04);
}

.search-icon {
  flex: none;
  width: 25rpx;
  height: 25rpx;
  border: 4rpx solid #d7bac5;
  border-radius: 50%;
}

.search-icon::after {
  display: block;
  width: 10rpx;
  height: 4rpx;
  margin: 18rpx 0 0 17rpx;
  border-radius: 2rpx;
  background: #d7bac5;
  content: '';
  transform: rotate(45deg);
}

.search-input {
  flex: 1;
  min-width: 0;
  height: 73rpx;
  color: #3d2f33;
  font-size: 26rpx;
}

.search-placeholder {
  color: #c9adb8;
}

.clear-search {
  width: 46rpx;
  height: 46rpx;
  border-radius: 50%;
  background: #f7f0f3;
  color: #a58a94;
  font-size: 31rpx;
  line-height: 44rpx;
}

.picker-loading {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 15rpx;
  padding: 77rpx 23rpx;
  color: #a58a94;
  font-size: 23rpx;
}

.loading-dot {
  width: 17rpx;
  height: 17rpx;
  border-radius: 50%;
  background: #d67a97;
  box-shadow: 27rpx 0 #d9b8c5, 54rpx 0 #b7a7d9;
  animation: pulse 1.1s ease-in-out infinite;
}

@keyframes pulse {
  50% { opacity: 0.35; }
}

.idol-list {
  display: flex;
  flex-direction: column;
  gap: 27rpx;
}

.picker-card {
  display: flex;
  align-items: center;
  gap: 25rpx;
  min-height: 171rpx;
  padding: 27rpx;
  border: 3rpx solid transparent;
  border-radius: 35rpx;
  background: #ffffff;
  box-shadow: 0 6rpx 23rpx rgba(61, 46, 51, 0.04);
}

.picker-card-current {
  border-color: #f0c3d0;
}

.picker-avatar {
  position: relative;
  flex: none;
  width: 100rpx;
  height: 100rpx;
  overflow: hidden;
  border-radius: 50%;
}

.avatar-color-0 {
  background: linear-gradient(135deg, #e5a6c0, #a98ee3);
}

.avatar-color-1 {
  background: linear-gradient(135deg, #99bde9, #73d0bd);
}

.avatar-color-2 {
  background: linear-gradient(135deg, #f2bd98, #df78ad);
}

.avatar-color-3 {
  background: linear-gradient(135deg, #a58be0, #64bce5);
}

.picker-initial {
  position: absolute;
  top: 50%;
  left: 50%;
  color: #ffffff;
  font-size: 38rpx;
  font-weight: 600;
  transform: translate(-50%, -52%);
}

.picker-avatar-image {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  border-radius: 50%;
}

.picker-info {
  flex: 1;
  min-width: 0;
}

.picker-name-row {
  display: flex;
  align-items: center;
  gap: 13rpx;
}

.picker-name {
  overflow: hidden;
  color: #3d2f33;
  font-size: 30rpx;
  font-weight: 700;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.current-badge {
  flex: none;
  padding: 4rpx 12rpx;
  border-radius: 13rpx;
  background: #fdf0f3;
  color: #c4526e;
  font-size: 19rpx;
  font-weight: 600;
}

.picker-bio,
.source-count {
  display: block;
}

.picker-bio {
  display: -webkit-box;
  overflow: hidden;
  margin-top: 6rpx;
  color: #a08b95;
  font-size: 22rpx;
  line-height: 1.5;
  word-break: break-all;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
}

.source-count {
  margin-top: 4rpx;
  color: #b59aa5;
  font-size: 21rpx;
}

.pick-button {
  flex: none;
  padding: 13rpx 25rpx;
  border-radius: 25rpx;
  background: linear-gradient(135deg, #e78aa4, #c4526e);
  color: #ffffff;
  font-size: 23rpx;
  font-weight: 600;
  line-height: 1.2;
  text-align: center;
}

.pick-button-disabled {
  background: #f7f0f3;
  color: #c0a8b2;
}

.no-result {
  padding: 67rpx 31rpx;
  border-radius: 35rpx;
  background: #ffffff;
  text-align: center;
}

.no-result-symbol {
  display: block;
  margin-bottom: 15rpx;
  color: #d49aad;
  font-size: 52rpx;
}

.picker-footnote {
  display: block;
  padding: 8rpx 0;
  color: #c0a8b2;
  font-size: 22rpx;
  text-align: center;
}
