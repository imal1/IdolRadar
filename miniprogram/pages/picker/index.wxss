.picker-page {
  display: flex;
  flex-direction: column;
  gap: 28rpx;
}

.picker-intro {
  padding: 12rpx 8rpx 0;
}

.picker-title,
.picker-subtitle {
  display: block;
}

.picker-title {
  color: #3d2f33;
  font-size: 44rpx;
  font-weight: 700;
}

.picker-subtitle {
  margin-top: 20rpx;
  color: #a58a94;
  font-size: 25rpx;
}

.search-box {
  display: flex;
  align-items: center;
  gap: 16rpx;
  min-height: 76rpx;
  padding: 0 28rpx;
  border-radius: 32rpx;
  background: #ffffff;
  box-shadow: 0 6rpx 20rpx rgba(61, 46, 51, 0.04);
}

.search-icon {
  flex: none;
  width: 26rpx;
  height: 26rpx;
  border: 4rpx solid #d7bac5;
  border-radius: 50%;
}

.search-icon::after {
  display: block;
  width: 10rpx;
  height: 4rpx;
  margin: 19rpx 0 0 18rpx;
  border-radius: 2rpx;
  background: #d7bac5;
  content: '';
  transform: rotate(45deg);
}

.search-input {
  flex: 1;
  min-width: 0;
  height: 76rpx;
  color: #3d2f33;
  font-size: 27rpx;
}

.search-placeholder {
  color: #c9adb8;
}

.clear-search {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: #f7f0f3;
  color: #a58a94;
  font-size: 32rpx;
  line-height: 46rpx;
}

.picker-loading {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  padding: 80rpx 24rpx;
  color: #a58a94;
  font-size: 24rpx;
}

.loading-dot {
  width: 18rpx;
  height: 18rpx;
  border-radius: 50%;
  background: #d67a97;
  box-shadow: 28rpx 0 #d9b8c5, 56rpx 0 #b7a7d9;
  animation: pulse 1.1s ease-in-out infinite;
}

@keyframes pulse {
  50% { opacity: 0.35; }
}

.idol-list {
  display: flex;
  flex-direction: column;
  gap: 28rpx;
}

.picker-card {
  display: flex;
  align-items: center;
  gap: 26rpx;
  min-height: 178rpx;
  padding: 28rpx;
  border: 3rpx solid transparent;
  border-radius: 36rpx;
  background: #ffffff;
  box-shadow: 0 6rpx 24rpx rgba(61, 46, 51, 0.04);
}

.picker-card-current {
  border-color: #f0c3d0;
}

.picker-avatar {
  position: relative;
  flex: none;
  width: 104rpx;
  height: 104rpx;
  overflow: hidden;
  border-radius: 50%;
}

.avatar-color-0 {
  background: linear-gradient(135deg, #e5a6c0, #a98ee3);
}

.avatar-color-1 {
  background: linear-gradient(135deg, #99bde9, #73d0bd);
}

.avatar-color-2 {
  background: linear-gradient(135deg, #f2bd98, #df78ad);
}

.avatar-color-3 {
  background: linear-gradient(135deg, #a58be0, #64bce5);
}

.picker-initial {
  position: absolute;
  top: 50%;
  left: 50%;
  color: #ffffff;
  font-size: 40rpx;
  font-weight: 500;
  transform: translate(-50%, -52%);
}

.picker-avatar-image {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  border-radius: 50%;
}

.picker-info {
  flex: 1;
  min-width: 0;
}

.picker-name-row {
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.picker-name {
  overflow: hidden;
  color: #3d2f33;
  font-size: 31rpx;
  font-weight: 700;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.current-badge {
  flex: none;
  padding: 4rpx 12rpx;
  border-radius: 14rpx;
  background: #fdf0f3;
  color: #c4526e;
  font-size: 20rpx;
  font-weight: 500;
}

.picker-bio,
.source-count {
  display: block;
}

.picker-bio {
  display: -webkit-box;
  overflow: hidden;
  margin-top: 6rpx;
  color: #a08b95;
  font-size: 23rpx;
  line-height: 1.5;
  word-break: break-all;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
}

.source-count {
  margin-top: 4rpx;
  color: #b59aa5;
  font-size: 22rpx;
}

.pick-button {
  flex: none;
  min-width: 118rpx;
  height: 56rpx;
  padding: 0 20rpx;
  border-radius: 26rpx;
  background: linear-gradient(135deg, #e78aa4, #c4526e);
  color: #ffffff;
  font-size: 24rpx;
  font-weight: 500;
  line-height: 56rpx;
}

.pick-button-disabled {
  background: #f7f0f3;
  color: #c0a8b2;
}

.no-result {
  padding: 70rpx 32rpx;
  border-radius: 36rpx;
  background: #ffffff;
  text-align: center;
}

.no-result-symbol {
  display: block;
  margin-bottom: 16rpx;
  color: #d49aad;
  font-size: 54rpx;
}

.picker-footnote {
  display: block;
  padding: 8rpx 0;
  color: #c0a8b2;
  font-size: 23rpx;
  text-align: center;
}
