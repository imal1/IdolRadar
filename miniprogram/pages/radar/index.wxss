.radar-page {
  display: flex;
  flex-direction: column;
  gap: 27rpx;
}

.loading-card {
  padding: 106rpx 35rpx;
  border-radius: 42rpx;
  background: linear-gradient(155deg, #fbe4e8, #f4e6f2 40%, #ece7f6);
  text-align: center;
}

.loading-orbit {
  width: 56rpx;
  height: 56rpx;
  margin: 0 auto 27rpx;
  border: 5rpx solid rgba(196, 82, 110, 0.18);
  border-top-color: #c4526e;
  border-radius: 50%;
  animation: orbit 0.9s linear infinite;
}

@keyframes orbit {
  to { transform: rotate(360deg); }
}

.idol-header {
  position: relative;
  overflow: hidden;
  padding: 35rpx 35rpx 31rpx;
  border-radius: 42rpx;
  background: linear-gradient(155deg, #fbe4e8 0%, #f4e6f2 40%, #ece7f6 100%);
  box-shadow: 0 12rpx 38rpx rgba(196, 82, 110, 0.1);
}

.sweep-light {
  position: absolute;
  top: 0;
  left: 0;
  bottom: 0;
  width: 45%;
  background: linear-gradient(105deg, transparent, rgba(255, 255, 255, 0.55), transparent);
  animation: sweep 3.8s ease-in-out infinite;
  pointer-events: none;
}

@keyframes sweep {
  from { transform: translateX(-120%); }
  to { transform: translateX(240%); }
}

.idol-row {
  display: flex;
  align-items: center;
  gap: 27rpx;
}

.avatar {
  position: relative;
  flex: none;
  overflow: visible;
  border-radius: 50%;
  background: linear-gradient(135deg, #e59bbc, #a997e5);
}

.avatar-large {
  width: 123rpx;
  height: 123rpx;
  border: 6rpx solid #ffffff;
  animation: breathe 2.6s ease-out infinite;
}

@keyframes breathe {
  0%, 100% { box-shadow: 0 0 0 0 rgba(228, 120, 150, 0.35); }
  50% { box-shadow: 0 0 0 27rpx rgba(228, 120, 150, 0); }
}

.avatar-initial {
  position: absolute;
  top: 50%;
  left: 50%;
  color: #ffffff;
  font-size: 46rpx;
  font-weight: 600;
  transform: translate(-50%, -52%);
}

.avatar-image {
  position: absolute;
  z-index: 1;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  border-radius: 50%;
}

.online-dot {
  position: absolute;
  z-index: 2;
  right: -1rpx;
  bottom: -1rpx;
  width: 27rpx;
  height: 27rpx;
  border: 5rpx solid #ffffff;
  border-radius: 50%;
  background: #5ec98f;
}

.idol-info {
  flex: 1;
  min-width: 0;
}

.idol-name-row {
  display: flex;
  align-items: center;
  gap: 15rpx;
}

.idol-name {
  overflow: hidden;
  color: #3d2f33;
  font-size: 38rpx;
  font-weight: 700;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.business-badge {
  flex: none;
  padding: 4rpx 13rpx;
  border-radius: 15rpx;
  background: rgba(255, 255, 255, 0.7);
  color: #c4526e;
  font-size: 21rpx;
  font-weight: 600;
}

.signal-row {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin-top: 8rpx;
  color: #8a7580;
  font-size: 23rpx;
}

.signal-dot {
  flex: none;
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #e47896;
  animation: blink 1.8s infinite;
}

@keyframes blink {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.25; }
}

.change-button {
  flex: none;
  padding: 12rpx 19rpx;
  border-radius: 23rpx;
  background: rgba(255, 255, 255, 0.6);
  color: #a58a94;
  font-size: 23rpx;
}

.stats-row {
  display: flex;
  gap: 15rpx;
  margin-top: 27rpx;
}

.stat-cell {
  display: flex;
  flex: 1;
  flex-direction: column;
  align-items: center;
  padding: 17rpx 8rpx;
  border-radius: 27rpx;
  background: rgba(255, 255, 255, 0.65);
}

.stat-value {
  color: #3d2f33;
  font-size: 33rpx;
  font-weight: 700;
}

.stat-accent {
  color: #c4526e;
}

.stat-label {
  margin-top: 2rpx;
  color: #a58a94;
  font-size: 21rpx;
}

.subscribe-banner {
  display: flex;
  align-items: center;
  gap: 19rpx;
  padding: 21rpx 27rpx;
  border: 2rpx dashed #ecb7c5;
  border-radius: 31rpx;
  background: #ffffff;
}

.reminder-icon {
  flex: none;
  width: 65rpx;
  height: 65rpx;
}

.reminder-moon {
  display: flex;
  flex: none;
  align-items: center;
  justify-content: center;
  width: 65rpx;
  height: 65rpx;
  border-radius: 22rpx;
  background: linear-gradient(140deg, #8b7fd6, #584a9c);
  color: #fdf7ff;
  font-size: 34rpx;
  text-shadow: 0 0 18rpx rgba(205, 195, 255, 0.8);
}

.subscribe-copy {
  display: flex;
  flex: 1;
  min-width: 0;
  flex-direction: column;
}

.subscribe-title {
  color: #3d2f33;
  font-size: 25rpx;
  font-weight: 600;
}

.subscribe-subtitle {
  margin-top: 2rpx;
  color: #a58a94;
  font-size: 21rpx;
}

.subscribe-button {
  flex: none;
}

.section-heading {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  padding: 0 8rpx;
}

.section-title {
  color: #3d2f33;
  font-size: 29rpx;
  font-weight: 700;
}

.section-note {
  color: #b59aa5;
  font-size: 21rpx;
}

.latest-card {
  padding: 31rpx;
  border: 3rpx solid #f5d4dd;
  border-radius: 38rpx;
  background: #ffffff;
  box-shadow: 0 8rpx 31rpx rgba(61, 46, 51, 0.05);
  animation: floatin 0.5s ease;
}

@keyframes floatin {
  from {
    opacity: 0;
    transform: translateY(19rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.post-meta {
  display: flex;
  align-items: center;
  gap: 13rpx;
}

.caught-tag,
.channel-tag {
  flex: none;
  padding: 6rpx 15rpx;
  border-radius: 15rpx;
  font-size: 21rpx;
}

.caught-tag {
  background: linear-gradient(135deg, #e78aa4, #c4526e);
  color: #ffffff;
  font-weight: 700;
}

.channel-purple {
  background: #f1ecfa;
  color: #8f7fa8;
}

.channel-blue {
  background: #eaf3fa;
  color: #4d8fb8;
}

.channel-green {
  background: #eaf6f0;
  color: #4f9e7a;
}

.channel-pink {
  background: #fdf0f3;
  color: #c4526e;
}

.post-time {
  flex: 1;
  color: #b59aa5;
  font-size: 21rpx;
  text-align: right;
}

.latest-title,
.latest-summary,
.feed-title,
.feed-summary {
  display: block;
  word-break: break-all;
}

.latest-title {
  margin-top: 19rpx;
  color: #3d2f33;
  font-size: 29rpx;
  font-weight: 600;
  line-height: 1.5;
}

.latest-summary {
  margin-top: 15rpx;
  color: #8a7580;
  font-size: 24rpx;
  line-height: 1.65;
}

.copy-button {
  display: inline-flex;
  margin-top: 23rpx;
  padding: 12rpx 23rpx;
  border-radius: 23rpx;
  background: #fdf0f3;
  color: #c4526e;
  font-size: 23rpx;
}

.empty-card {
  padding: 54rpx 31rpx;
  border: 3rpx solid #f5d4dd;
  border-radius: 38rpx;
  background: #ffffff;
  text-align: center;
}

.empty-symbol {
  display: block;
  margin-bottom: 17rpx;
  color: #d589a1;
  font-size: 46rpx;
}

.previous-heading {
  margin-top: 4rpx;
}

.feed-list {
  overflow: hidden;
  border-radius: 38rpx;
  background: #ffffff;
  box-shadow: 0 8rpx 31rpx rgba(61, 46, 51, 0.04);
}

.feed-item {
  padding: 25rpx 31rpx;
  border-bottom: 2rpx solid #f7eef1;
}

.feed-item:last-child {
  border-bottom: 0;
}

.feed-title {
  margin-top: 10rpx;
  color: #3d2f33;
  font-size: 26rpx;
  font-weight: 600;
  line-height: 1.45;
}

.feed-summary {
  margin-top: 8rpx;
  color: #a08b95;
  font-size: 22rpx;
  line-height: 1.55;
}

.feed-footer {
  padding: 8rpx 0 19rpx;
  color: #c0a8b2;
  font-size: 21rpx;
  text-align: center;
}
