.radar-page {
  display: flex;
  flex-direction: column;
  gap: 28rpx;
}

.loading-card {
  padding: 110rpx 36rpx;
  border-radius: 44rpx;
  background: linear-gradient(155deg, #fbe4e8, #f4e6f2 40%, #ece7f6);
  text-align: center;
}

.loading-orbit {
  width: 58rpx;
  height: 58rpx;
  margin: 0 auto 28rpx;
  border: 5rpx solid rgba(196, 82, 110, 0.18);
  border-top-color: #c4526e;
  border-radius: 50%;
  animation: orbit 0.9s linear infinite;
}

@keyframes orbit {
  to { transform: rotate(360deg); }
}

.idol-header {
  padding: 36rpx 36rpx 32rpx;
  border-radius: 44rpx;
  background: linear-gradient(155deg, #fbe4e8 0%, #f4e6f2 40%, #ece7f6 100%);
  box-shadow: 0 12rpx 40rpx rgba(196, 82, 110, 0.1);
}

.idol-row {
  display: flex;
  align-items: center;
  gap: 28rpx;
}

.avatar {
  position: relative;
  flex: none;
  overflow: visible;
  border-radius: 50%;
  background: linear-gradient(135deg, #e59bbc, #a997e5);
}

.avatar-large {
  width: 128rpx;
  height: 128rpx;
}

.avatar-initial {
  position: absolute;
  top: 50%;
  left: 50%;
  color: #ffffff;
  font-size: 48rpx;
  font-weight: 500;
  transform: translate(-50%, -52%);
}

.avatar-image {
  position: absolute;
  z-index: 1;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  border-radius: 50%;
}

.online-dot {
  position: absolute;
  z-index: 2;
  right: -1rpx;
  bottom: -1rpx;
  width: 28rpx;
  height: 28rpx;
  border: 5rpx solid #f4e6f2;
  border-radius: 50%;
  background: #67d59b;
}

.idol-info {
  flex: 1;
  min-width: 0;
}

.idol-name-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.idol-name {
  overflow: hidden;
  color: #3d2f33;
  font-size: 40rpx;
  font-weight: 700;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.business-badge {
  flex: none;
  padding: 4rpx 14rpx;
  border-radius: 16rpx;
  background: rgba(255, 255, 255, 0.7);
  color: #c4526e;
  font-size: 22rpx;
  font-weight: 500;
}

.signal-row {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin-top: 8rpx;
  color: #8a7580;
  font-size: 24rpx;
}

.signal-dot {
  flex: none;
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #e78aa4;
}

.change-button {
  flex: none;
  padding: 12rpx 20rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.6);
  color: #a58a94;
  font-size: 24rpx;
}

.stats-row {
  display: flex;
  gap: 16rpx;
  margin-top: 28rpx;
}

.stat-cell {
  display: flex;
  flex: 1;
  flex-direction: column;
  align-items: center;
  padding: 18rpx 8rpx;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.65);
}

.stat-value {
  color: #3d2f33;
  font-size: 34rpx;
  font-weight: 700;
}

.stat-accent {
  color: #c4526e;
}

.stat-label {
  margin-top: 2rpx;
  color: #a58a94;
  font-size: 22rpx;
}

.subscribe-banner {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 22rpx 28rpx;
  border: 2rpx dashed #ecb7c5;
  border-radius: 32rpx;
  background: #ffffff;
}

.reminder-icon {
  flex: none;
  width: 68rpx;
  height: 68rpx;
}

.subscribe-copy {
  display: flex;
  flex: 1;
  min-width: 0;
  flex-direction: column;
}

.subscribe-title {
  color: #3d2f33;
  font-size: 26rpx;
  font-weight: 500;
}

.subscribe-subtitle {
  margin-top: 2rpx;
  color: #a58a94;
  font-size: 22rpx;
}

.subscribe-button {
  flex: none;
}

.section-heading {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  padding: 0 8rpx;
}

.section-title {
  color: #3d2f33;
  font-size: 30rpx;
  font-weight: 700;
}

.section-note {
  color: #b59aa5;
  font-size: 22rpx;
}

.latest-card {
  padding: 32rpx;
  border: 3rpx solid #f5d4dd;
  border-radius: 40rpx;
  background: #ffffff;
  box-shadow: 0 8rpx 32rpx rgba(61, 46, 51, 0.05);
}

.post-meta {
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.caught-tag,
.channel-tag {
  flex: none;
  padding: 6rpx 16rpx;
  border-radius: 16rpx;
  font-size: 22rpx;
}

.caught-tag {
  background: linear-gradient(135deg, #e78aa4, #c4526e);
  color: #ffffff;
  font-weight: 700;
}

.channel-purple {
  background: #f1ecfa;
  color: #8f7fa8;
}

.channel-blue {
  background: #eaf3fa;
  color: #4d8fb8;
}

.channel-green {
  background: #eaf6f0;
  color: #4f9e7a;
}

.channel-pink {
  background: #fdf0f3;
  color: #c4526e;
}

.post-time {
  flex: 1;
  color: #b59aa5;
  font-size: 22rpx;
  text-align: right;
}

.latest-title,
.latest-summary,
.feed-title,
.feed-summary {
  display: block;
  word-break: break-all;
}

.latest-title {
  margin-top: 20rpx;
  color: #3d2f33;
  font-size: 30rpx;
  font-weight: 500;
  line-height: 1.5;
}

.latest-summary {
  margin-top: 16rpx;
  color: #8a7580;
  font-size: 25rpx;
  line-height: 1.65;
}

.copy-button {
  display: inline-flex;
  margin-top: 24rpx;
  padding: 12rpx 24rpx;
  border-radius: 24rpx;
  background: #fdf0f3;
  color: #c4526e;
  font-size: 24rpx;
}

.empty-card {
  padding: 56rpx 32rpx;
  border: 3rpx solid #f5d4dd;
  border-radius: 40rpx;
  background: #ffffff;
  text-align: center;
}

.empty-symbol {
  display: block;
  margin-bottom: 18rpx;
  color: #d589a1;
  font-size: 48rpx;
}

.previous-heading {
  margin-top: 4rpx;
}

.feed-list {
  overflow: hidden;
  border-radius: 40rpx;
  background: #ffffff;
  box-shadow: 0 8rpx 32rpx rgba(61, 46, 51, 0.04);
}

.feed-item {
  padding: 26rpx 32rpx;
  border-bottom: 2rpx solid #f7eef1;
}

.feed-item:last-child {
  border-bottom: 0;
}

.feed-title {
  margin-top: 10rpx;
  color: #3d2f33;
  font-size: 27rpx;
  font-weight: 500;
  line-height: 1.45;
}

.feed-summary {
  margin-top: 8rpx;
  color: #a08b95;
  font-size: 23rpx;
  line-height: 1.55;
}

.feed-footer {
  padding: 8rpx 0 20rpx;
  color: #c0a8b2;
  font-size: 22rpx;
  text-align: center;
}
