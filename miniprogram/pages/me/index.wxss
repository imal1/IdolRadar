.me-page {
  display: flex;
  flex-direction: column;
  gap: 27rpx;
}

.me-loading {
  display: flex;
  align-items: center;
  gap: 27rpx;
  padding: 38rpx 35rpx;
  border-radius: 42rpx;
  background: linear-gradient(165deg, #fbe4e8, #ece7f6);
}

.me-loading-avatar {
  width: 108rpx;
  height: 108rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.8);
}

.me-loading-lines {
  flex: 1;
}

.me-loading-lines view {
  width: 48%;
  height: 23rpx;
  border-radius: 12rpx;
  background: rgba(255, 255, 255, 0.75);
}

.me-loading-lines view:last-child {
  width: 70%;
  height: 17rpx;
  margin-top: 13rpx;
}

.profile-card {
  display: flex;
  align-items: center;
  gap: 27rpx;
  padding: 38rpx 35rpx;
  border-radius: 42rpx;
  background: linear-gradient(165deg, #fbe4e8, #ece7f6);
}

.user-avatar {
  display: flex;
  flex: none;
  align-items: center;
  justify-content: center;
  width: 108rpx;
  height: 108rpx;
  border-radius: 50%;
  background: #ffffff;
  color: #d3a4b5;
  font-size: 42rpx;
}

.profile-copy,
.guard-copy,
.reminder-copy {
  display: flex;
  flex: 1;
  min-width: 0;
  flex-direction: column;
}

.profile-name {
  color: #3d2f33;
  font-size: 31rpx;
  font-weight: 700;
}

.profile-note {
  margin-top: 6rpx;
  color: #a58a94;
  font-size: 22rpx;
}

.me-card {
  padding: 31rpx;
  border-radius: 38rpx;
  background: #ffffff;
  box-shadow: 0 8rpx 31rpx rgba(61, 46, 51, 0.04);
}

.card-label {
  display: block;
  margin-bottom: 23rpx;
  color: #b59aa5;
  font-size: 23rpx;
  font-weight: 600;
}

.guard-row,
.reminder-row {
  display: flex;
  align-items: center;
  gap: 23rpx;
}

.guard-avatar {
  position: relative;
  flex: none;
  width: 88rpx;
  height: 88rpx;
  overflow: hidden;
  border-radius: 50%;
  background: linear-gradient(135deg, #e5a6c0, #a98ee3);
}

.guard-initial {
  position: absolute;
  top: 50%;
  left: 50%;
  color: #ffffff;
  font-size: 35rpx;
  font-weight: 600;
  transform: translate(-50%, -52%);
}

.guard-avatar-image {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  border-radius: 50%;
}

.guard-name {
  overflow: hidden;
  color: #3d2f33;
  font-size: 29rpx;
  font-weight: 700;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.guard-note {
  margin-top: 4rpx;
  color: #a58a94;
  font-size: 21rpx;
}

.reminder-card {
  padding-bottom: 35rpx;
}

.reminder-title {
  color: #3d2f33;
  font-size: 27rpx;
  font-weight: 600;
}

.reminder-note {
  margin-top: 6rpx;
  color: #a58a94;
  font-size: 22rpx;
  line-height: 1.55;
}

.subscription-tip {
  margin-top: 23rpx;
  padding: 17rpx 23rpx;
  border-radius: 23rpx;
  background: #fdf7f9;
  color: #c0a8b2;
  font-size: 21rpx;
  line-height: 1.6;
}

.about-list {
  overflow: hidden;
  border-radius: 38rpx;
  background: #ffffff;
  box-shadow: 0 8rpx 31rpx rgba(61, 46, 51, 0.04);
}

.about-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  width: 100%;
  min-height: 88rpx;
  padding: 0 31rpx;
  border-bottom: 2rpx solid #f7eef1;
  background: #ffffff;
  color: #3d2f33;
  font-size: 26rpx;
  text-align: left;
}

.about-row:last-child {
  border-bottom: 0;
}

.about-value {
  color: #c0a8b2;
  font-size: 23rpx;
}

.slogan {
  display: block;
  padding: 4rpx 0;
  color: #cbb5be;
  font-size: 21rpx;
  text-align: center;
}
