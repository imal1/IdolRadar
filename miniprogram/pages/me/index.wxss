.me-page {
  display: flex;
  flex-direction: column;
  gap: 28rpx;
}

.me-loading {
  display: flex;
  align-items: center;
  gap: 28rpx;
  padding: 40rpx 36rpx;
  border-radius: 44rpx;
  background: linear-gradient(165deg, #fbe4e8, #ece7f6);
}

.me-loading-avatar {
  width: 112rpx;
  height: 112rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.8);
}

.me-loading-lines {
  flex: 1;
}

.me-loading-lines view {
  width: 48%;
  height: 24rpx;
  border-radius: 12rpx;
  background: rgba(255, 255, 255, 0.75);
}

.me-loading-lines view:last-child {
  width: 70%;
  height: 18rpx;
  margin-top: 14rpx;
}

.profile-card {
  display: flex;
  align-items: center;
  gap: 28rpx;
  padding: 40rpx 36rpx;
  border-radius: 44rpx;
  background: linear-gradient(165deg, #fbe4e8, #ece7f6);
}

.user-avatar {
  display: flex;
  flex: none;
  align-items: center;
  justify-content: center;
  width: 112rpx;
  height: 112rpx;
  border-radius: 50%;
  background: #ffffff;
  color: #d3a4b5;
  font-size: 44rpx;
}

.profile-copy,
.guard-copy,
.reminder-copy {
  display: flex;
  flex: 1;
  min-width: 0;
  flex-direction: column;
}

.profile-name {
  color: #3d2f33;
  font-size: 32rpx;
  font-weight: 700;
}

.profile-note {
  margin-top: 6rpx;
  color: #a58a94;
  font-size: 23rpx;
}

.me-card {
  padding: 32rpx;
  border-radius: 40rpx;
  background: #ffffff;
  box-shadow: 0 8rpx 32rpx rgba(61, 46, 51, 0.04);
}

.card-label {
  display: block;
  margin-bottom: 24rpx;
  color: #b59aa5;
  font-size: 24rpx;
  font-weight: 500;
}

.guard-row,
.reminder-row {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.guard-avatar {
  position: relative;
  flex: none;
  width: 92rpx;
  height: 92rpx;
  overflow: hidden;
  border-radius: 50%;
  background: linear-gradient(135deg, #e5a6c0, #a98ee3);
}

.guard-initial {
  position: absolute;
  top: 50%;
  left: 50%;
  color: #ffffff;
  font-size: 36rpx;
  font-weight: 500;
  transform: translate(-50%, -52%);
}

.guard-avatar-image {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  border-radius: 50%;
}

.guard-name {
  overflow: hidden;
  color: #3d2f33;
  font-size: 30rpx;
  font-weight: 700;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.guard-note {
  margin-top: 4rpx;
  color: #a58a94;
  font-size: 22rpx;
}

.reminder-card {
  padding-bottom: 36rpx;
}

.reminder-title {
  color: #3d2f33;
  font-size: 28rpx;
  font-weight: 500;
}

.reminder-note {
  margin-top: 6rpx;
  color: #a58a94;
  font-size: 23rpx;
  line-height: 1.55;
}

.subscription-tip {
  margin-top: 24rpx;
  padding: 18rpx 24rpx;
  border-radius: 24rpx;
  background: #fdf7f9;
  color: #c0a8b2;
  font-size: 22rpx;
  line-height: 1.6;
}

.about-list {
  overflow: hidden;
  border-radius: 40rpx;
  background: #ffffff;
  box-shadow: 0 8rpx 32rpx rgba(61, 46, 51, 0.04);
}

.about-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  width: 100%;
  min-height: 92rpx;
  padding: 0 32rpx;
  border-bottom: 2rpx solid #f7eef1;
  background: #ffffff;
  color: #3d2f33;
  font-size: 27rpx;
  text-align: left;
}

.about-row:last-child {
  border-bottom: 0;
}

.about-value {
  color: #c0a8b2;
  font-size: 24rpx;
}

.slogan {
  display: block;
  padding: 4rpx 0;
  color: #cbb5be;
  font-size: 22rpx;
  text-align: center;
}
