{
  "name": "idol-radar",
  "version": "0.1.0",
  "private": true,
  "description": "使用自建 Spring Boot 后端的追星动态雷达微信小程序",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "check": "npm run check:syntax && npm test && npm run validate",
