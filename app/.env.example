# 数据服务只监听服务器回环地址；密码应由部署环境单独生成。
POSTGRES_DB=idolradar_java
POSTGRES_USER=idolradar
POSTGRES_PASSWORD=replace-with-a-strong-postgres-password
POSTGRES_PORT=5432
DATABASE_POOL_SIZE=10

REDIS_PORT=16379
REDIS_USERNAME=
REDIS_PASSWORD=replace-with-a-different-strong-redis-password

# 2GB 服务器为 PostgreSQL、Redis、Nginx 预留内存。
JAVA_XMS=256m
JAVA_XMX=768m
APP_PORT=8080

WECHAT_APP_ID=replace-with-your-miniprogram-appid
WECHAT_APP_SECRET=replace-with-your-server-side-appsecret
WECHAT_API_BASE_URL=https://api.weixin.qq.com
SUBSCRIBE_TEMPLATE_ID=
MINIPROGRAM_STATE=trial
SESSION_TTL=30d
RATE_LIMIT_IP=1200
RATE_LIMIT_USER=120
RATE_LIMIT_LOGIN=20
RATE_LIMIT_SUBSCRIPTION=12

RSS_TIMEOUT=10s
RSS_MAX_RESPONSE_BYTES=2097152
RSS_MAX_REDIRECTS=3
RSS_MAX_ENTRIES_PER_SOURCE=100
RSS_SOURCE_CONCURRENCY=4
NOTIFY_CONCURRENCY=8
NOTIFICATION_LEASE=15m
NOTIFICATION_MAX_ATTEMPTS=5
NOTIFICATION_RETRY_BASE=1m
LOG_LEVEL=INFO
